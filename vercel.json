{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.0",
      "config": {
        "maxDuration": 10,
        "memory": 1024,
        "runtimeArgs": [
          "-d", "extension=openssl",
          "-d", "extension=mbstring"
        ]
      }
    }
  },
  "build": {
    "env": {
      "COMPOSER_MIRROR_PATH_REPOS": "1"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/dist/$1"
    },
    {
      "src": "/(css|js|images|favicon.ico)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}